# Copy this file to .env and fill in your values
# Never commit .env to git

# LLM providers
OPENAI_API_KEY=sk-...           # required for GPT-5.6-sol simulation fund
ANTHROPIC_API_KEY=sk-ant-...    # required for Claude Opus simulation fund

# Telegram bot (required for notifications)
TELEGRAM_BOT_TOKEN=...          # from @BotFather
TELEGRAM_CHAT_ID=...            # your personal chat ID (run /start with the bot, then check)

# Optional: Börsdata API (not used by default — yfinance only)
# BORSDATA_API_KEY=...

# Optional: override config.yaml values via env
# FUND_MODEL_ID=gpt-4o
# FUND_CAPITAL_SEK=50000

# Model used for screenshot OCR extraction (cheap text model, not vision)
# Default: gpt-4o-mini
# FUND_OCR_MODEL=gpt-4o-mini
