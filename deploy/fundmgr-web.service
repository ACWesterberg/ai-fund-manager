[Unit]
Description=AI Fund Manager — Web Dashboard
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/ai-fund-manager
EnvironmentFile=/home/pi/ai-fund-manager/.env
ExecStart=/home/pi/ai-fund-manager/.venv/bin/uvicorn fundmgr.web.app:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
