# AI Fund Manager — crontab
#
# IMPORTANT: set the Pi timezone first so times here track DST automatically:
#   sudo timedatectl set-timezone Europe/Stockholm
#   date   # verify
#
# Install with: crontab -e   (then paste the lines below)
# ─────────────────────────────────────────────────────────────────────────────

# ═══ NORDIC FUND (real trades) — OMX Stockholm, opens 09:00 CET ══════════════

# Weekly decision run — Monday 09:30 CET
# 30 min after open: price discovery done, spreads tight, full day ahead
30 9 * * 1 cd /home/alexander/Documents/ai-fund-manager && .venv/bin/fund run >> data/logs/weekly.log 2>&1

# News trigger checks — weekdays during Nordic trading hours
# Covers morning open, mid-session, early and late afternoon
0 9,11,14,16 * * 1-5 cd /home/alexander/Documents/ai-fund-manager && .venv/bin/fund check-news >> data/logs/news.log 2>&1

# Stop-loss checks — every 15 min during OMX trading hours (09:00–17:30 CET)
# Matches yfinance's 15-min data delay — checking more often gives no benefit
*/15 9-17 * * 1-5 cd /home/alexander/Documents/ai-fund-manager && .venv/bin/fund check-stops >> data/logs/stops.log 2>&1


# ═══ GLOBAL SIMULATION FUND (OpenAI GPT-5.6-sol) — NYSE/NASDAQ + European overlap ══
#
# Best execution window: 16:00 CET
#   - NYSE/NASDAQ open at 15:30 CET → 30 min in, opening noise settled
#   - European markets (XETRA, Euronext, LSE) still open until 17:30 CET
#   - Only window where both hemispheres are live simultaneously

# Weekly decision run — Monday 16:00 CET
0 16 * * 1 cd /home/alexander/Documents/ai-fund-manager && FUND_CONFIG=config/config_global.yaml .venv/bin/fund run >> data/logs/weekly_global.log 2>&1

# News trigger checks — weekdays during US trading hours
# 14:00: pre-market US sentiment; 18:00: mid NYSE session; 21:00: late NYSE / earnings window
0 14,18,21 * * 1-5 cd /home/alexander/Documents/ai-fund-manager && FUND_CONFIG=config/config_global.yaml .venv/bin/fund check-news >> data/logs/news_global.log 2>&1

# Stop-loss checks — every 15 min during NYSE trading hours (15:30–22:00 CET)
*/15 15-21 * * 1-5 cd /home/alexander/Documents/ai-fund-manager && FUND_CONFIG=config/config_global.yaml .venv/bin/fund check-stops >> data/logs/stops_global.log 2>&1


# ═══ CLAUDE SIMULATION FUND (Anthropic Claude Opus) — same universe as Global ══
#
# Runs 30 min after GPT-5.6-sol so both get same market conditions but decide independently

# Weekly decision run — Monday 16:30 CET
30 16 * * 1 cd /home/alexander/Documents/ai-fund-manager && FUND_CONFIG=config/config_claude.yaml .venv/bin/fund run >> data/logs/weekly_claude.log 2>&1

# News trigger checks — same windows as Global (same universe, same news sources)
0 14,18,21 * * 1-5 cd /home/alexander/Documents/ai-fund-manager && FUND_CONFIG=config/config_claude.yaml .venv/bin/fund check-news >> data/logs/news_claude.log 2>&1

# Stop-loss checks — every 15 min during NYSE trading hours (15:30–22:00 CET)
*/15 15-21 * * 1-5 cd /home/alexander/Documents/ai-fund-manager && FUND_CONFIG=config/config_claude.yaml .venv/bin/fund check-stops >> data/logs/stops_claude.log 2>&1


# ═══ PAPER PORTFOLIOS (created on the web at /paper) ═════════════════════════
#
# Daily upkeep for every data/paper/*.db: refresh price + benchmark caches,
# snapshot NAV at real market prices, evaluate matured outcomes (~4 weeks) and
# distil learnings — same pipeline as the funds. 22:15 CET = after NYSE close.

15 22 * * 1-5 cd /home/alexander/Documents/ai-fund-manager && .venv/bin/fund paper-track >> data/logs/paper.log 2>&1


# ═══ PROMPT OPTIMIZATION (DSPy MIPROv2) — Sunday, markets closed ═════════════
# Needs the optional dep (uv sync --extra optimize) + 30 evaluated outcomes and
# 8 scored runs per fund; skips harmlessly until then. Staggered per fund.

0 2 * * 0 cd /home/alexander/Documents/ai-fund-manager && .venv/bin/fund optimize >> data/logs/optimize.log 2>&1
30 2 * * 0 cd /home/alexander/Documents/ai-fund-manager && FUND_CONFIG=config/config_global.yaml .venv/bin/fund optimize >> data/logs/optimize_global.log 2>&1
0 3 * * 0 cd /home/alexander/Documents/ai-fund-manager && FUND_CONFIG=config/config_claude.yaml .venv/bin/fund optimize >> data/logs/optimize_claude.log 2>&1


# ═══ BACKUPS — SQLite DBs → Google Drive (rclone) ════════════════════════════
# See deploy/BACKUP.md for one-time rclone setup.

# Daily backup — 03:00 CET
0 3 * * * cd /home/alexander/Documents/ai-fund-manager && deploy/backup.sh >> data/logs/backup.log 2>&1

# Post-run snapshots after the Monday decision runs (captures post-decision state)
0 11 * * 1 cd /home/alexander/Documents/ai-fund-manager && deploy/backup.sh >> data/logs/backup.log 2>&1
0 18 * * 1 cd /home/alexander/Documents/ai-fund-manager && deploy/backup.sh >> data/logs/backup.log 2>&1
